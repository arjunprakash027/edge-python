# WASM: content-addressed via version.json, safe to cache forever.
/compiler_lib.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

# Static runtime files: cache long, revalidate on hash change.
/runtime/*
  Cache-Control: public, max-age=31536000, immutable

# Hashed CSS/JS bundles.
/tailwind.css
  Cache-Control: public, max-age=31536000, immutable

# version.json: never cache, this is the cache-busting source of truth.
/version.json
  Cache-Control: no-cache, no-store, must-revalidate

# HTML: short cache so users get new versions quickly.
/index.html
  Cache-Control: public, max-age=60, must-revalidate
/
  Cache-Control: public, max-age=60, must-revalidate
